# Entorno virtual
.venv/
__pycache__/
*.py[cod]

# Datos - ignorar archivos pero preservar estructura de carpetas
data/**/*.jpg
data/**/*.jpeg
data/**/*.png
data/**/*.bmp
data/**/*.tiff
data/**/*.tif
data/**/*.webp
data/**/*.txt
data/**/*.json
data/**/*.xml
data/**/*.yaml
data/**/*.yml
data/**/*.csv
data/**/*.npy
data/**/*.npz
data/**/*.pkl
data/**/*.cache

# Pesos de modelos
*.pt
*.pth
*.onnx

# Salidas de entrenamiento
runs/**
!runs/.gitkeep
outputs/**
!outputs/.gitkeep

# Excepto los modelos finales para produccion (Streamlit)
!checkpoints/classification/best_model.pt
!checkpoints/segmentation/best_model.pt

# Logs
*.log
logs/**
!logs/.gitkeep
mlruns/

# Jupyter
.ipynb_checkpoints/

# IDEs
.vscode/
.idea/
.DS_Store

# Tests
.coverage
htmlcov/
.pytest_cache/

# Linting
.ruff_cache/

# Builds
dist/
build/
*.egg-info/
